{
  "name": "mcp-conductor",
  "private": true,
  "version": "0.2.0",
  "description": "Tool gateway for AI agents (MCP + OpenAPI + GraphQL) with auth/groups and audit",
  "type": "module",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r --filter \"./packages/*\" run typecheck",
    "clean": "rimraf \"packages/*/dist\" \"packages/*/.tsbuildinfo\" coverage",
    "dev": "tsx packages/server/src/cli.ts",
    "hash-key": "tsx scripts/hash-api-key.ts"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
