{
  "name": "@mcp-conductor/gateway",
  "version": "0.2.0",
  "description": "HTTP MCP gateway: auth, group access, audit, consumes any ToolProvider[]",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
