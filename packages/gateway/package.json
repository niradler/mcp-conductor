    "@opentelemetry/api": "^1.9.0",
    "hono": "^4.6.14",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@mcp-conductor/core": "workspace:*",
    "@mcp-conductor/provider-mcp": "workspace:*"
  }
