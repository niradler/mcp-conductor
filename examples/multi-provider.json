  "providers": [
    {
      "type": "mcp",
      "name": "everything",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-everything"],
      "env": {}
    },
    {
      "type": "mcp",
      "name": "filesystem",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/tmp/mcp-conductor-shared"],
      "env": {},
      "allow_tools": ["read_file", "read_multiple_files", "list_directory", "search_files", "get_file_info"]
    },
    {
      "type": "mcp",
      "name": "time",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-time"],
      "env": {},
      "exclude_tools": ["set_time"]
    }
  ],
  "audit": {
    "type": "console"
  },
  "telemetry": {
    "serviceName": "mcp-conductor",
    "otlpEndpoint": ""
